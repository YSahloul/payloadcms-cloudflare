---
/**
 * CTA Block — closer parity with original Payblocks CTA variants.
 * Source of truth:
 *   - src/blocks/Cta/cta1.tsx
 *   - src/blocks/Cta/cta6.tsx
 *   - src/blocks/Cta/cta10.tsx
 *   - src/blocks/Cta/cta12.tsx
 *
 * Content only — wrapped by SectionShell.
 */
import RichTextLexical from '../richtext/RichTextLexical.astro'
import { resolveLinkUrl, buildButtonClasses } from '../../../lib/styles'

const { richText, links, designVersion, icon, image, title } = Astro.props
const variant = designVersion || 'CTA1'
const nodes = richText?.root?.children || []

const headingTypes = new Set(['h2', 'h3', 'h4'])
let firstNode: any[] = []
let restNodes: any[] = []
let foundHeading = false
for (const node of nodes) {
  if (!foundHeading && node?.type === 'heading' && headingTypes.has(node?.tag)) {
    firstNode = [node]
    foundHeading = true
    continue
  }
  if (foundHeading) {
    restNodes.push(node)
  }
}

const fullRichText = richText?.root?.children?.length > 0
const firstHeading = firstNode.length > 0
const rest = restNodes.length > 0

function hrefFor(link: any) {
  return resolveLinkUrl(link)
}
---

{/* CTA6 — original stacked-card visual */}
{
  variant === 'CTA6' && (
    <div class="border-border bg-accent max-w-full overflow-hidden border-y pt-10 md:pt-16 lg:pt-20">
      <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row md:space-x-12">
        <div class="mb-72 md:mb-28 md:w-2/3 lg:shrink-0 xl:mb-20 xl:w-1/2">
          {fullRichText && (
            <div>
              <RichTextLexical
                nodes={nodes}
                overrideStyle={{
                  h2: 'mb-3 text-4xl font-semibold md:mb-4 md:text-5xl lg:mb-6',
                  h3: 'mb-3 text-4xl font-semibold md:mb-4 md:text-5xl lg:mb-6',
                  p: 'text-muted-foreground lg:text-lg mb-8',
                }}
              />
            </div>
          )}
          <div class="flex shrink-0 flex-col gap-2 sm:flex-row">
            {Array.isArray(links) && links.length > 0 && (
              <>
                {links.map(({ link }: any, i: number) => (
                  <a
                    href={hrefFor(link)}
                    target={link?.newTab ? '_blank' : undefined}
                    rel={link?.newTab ? 'noopener noreferrer' : undefined}
                    class:list={[
                      buildButtonClasses(link?.appearance || 'default', link?.size || 'default'),
                      'w-full sm:w-auto',
                    ]}
                  >
                    {link?.label}
                  </a>
                ))}
              </>
            )}
          </div>
        </div>
        <div class="absolute right-1/2 bottom-0 mr-6 h-min w-[110%] max-w-md translate-x-1/2 md:-right-36 md:mr-0 md:w-3/4 md:max-w-xl md:translate-x-0 lg:mt-auto xl:relative xl:right-0 xl:size-full xl:max-w-full">
          <div class="relative aspect-[8/5] size-full min-h-64">
            <div class="bg-background shadow-foreground/20 absolute top-0 right-0 z-40 flex aspect-[3/5] w-3/5 -translate-x-[24%] translate-y-[24%] -rotate-[30deg] justify-center rounded-3xl text-clip shadow-lg md:max-xl:-translate-x-[8%] md:max-xl:translate-y-[16%]"></div>
            <div class="bg-background shadow-foreground/20 absolute top-0 right-0 z-40 flex aspect-[3/5] w-3/5 -translate-x-[16%] translate-y-[8%] -rotate-[15deg] justify-center rounded-3xl text-clip shadow-xl md:max-xl:-translate-x-[6%] md:max-xl:translate-y-[6%]"></div>
            <div class="bg-background shadow-foreground/20 absolute top-0 right-0 z-40 flex aspect-[3/5] w-3/5 items-center justify-center rounded-3xl text-clip shadow-2xl overflow-hidden">
              {image?.url && (
                <img
                  src={image.url}
                  alt={image.alt || title || ''}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  )
}

{/* CTA10 — original split box */}
{
  variant === 'CTA10' && (
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="bg-accent flex w-full flex-col gap-16 overflow-hidden rounded-lg p-8 md:rounded-xl lg:flex-row lg:items-center lg:p-16">
        <div class="flex-1">
          {fullRichText && (
            <RichTextLexical
              nodes={nodes}
              overrideStyle={{
                h3: 'mb-3 text-2xl font-semibold md:mb-4 md:text-4xl lg:mb-6',
                p: 'text-muted-foreground lg:text-lg',
              }}
            />
          )}
        </div>
        <div class="flex shrink-0 flex-col gap-2 sm:flex-row">
          {Array.isArray(links) && links.length > 0 && (
            <>
              {links.map(({ link }: any, i: number) => (
                <a
                  href={hrefFor(link)}
                  target={link?.newTab ? '_blank' : undefined}
                  rel={link?.newTab ? 'noopener noreferrer' : undefined}
                  class:list={[
                    buildButtonClasses(link?.appearance || 'default', link?.size || 'default'),
                    'w-full sm:w-auto',
                  ]}
                >
                  {link?.label}
                </a>
              ))}
            </>
          )}
        </div>
      </div>
    </div>
  )
}

{/* CTA12 — original centered accent box */}
{
  variant === 'CTA12' && (
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="bg-accent rounded-lg p-8 md:rounded-xl lg:p-12">
        <div class="mx-auto max-w-4xl text-center">
          {fullRichText && (
            <RichTextLexical
              nodes={nodes}
              overrideStyle={{
                h2: 'mb-4 text-3xl font-semibold md:text-5xl lg:mb-6 lg:text-6xl',
                h3: 'mb-4 text-3xl font-semibold md:text-5xl lg:mb-6 lg:text-6xl',
                h4: 'mb-4 text-3xl font-semibold md:text-5xl lg:mb-6 lg:text-6xl',
                p: 'text-muted-foreground mb-8 text-lg font-medium lg:text-xl',
              }}
            />
          )}
          <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
            {Array.isArray(links) && links.length > 0 && (
              <>
                {links.map(({ link }: any, i: number) => (
                  <a
                    href={hrefFor(link)}
                    target={link?.newTab ? '_blank' : undefined}
                    rel={link?.newTab ? 'noopener noreferrer' : undefined}
                    class:list={[
                      buildButtonClasses(link?.appearance || 'default', link?.size || 'default'),
                      'w-full sm:w-auto',
                    ]}
                  >
                    {link?.label}
                  </a>
                ))}
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  )
}

{/* CTA1 — original card + image split */}
{
  (variant === 'CTA1' || !['CTA6', 'CTA10', 'CTA12'].includes(variant)) && (
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="bg-card text-card-foreground border flex flex-col justify-between rounded-xl md:flex-row overflow-hidden shadow-sm">
        <div class="p-6 md:max-w-96">
          <div class="mb-2 flex items-center gap-2">
            <span class="bg-muted flex size-7 items-center justify-center rounded-full text-sm">
              {icon || null}
            </span>
            {firstHeading && (
              <div class="[&_h1]:text-2xl [&_h1]:font-bold [&_h2]:text-2xl [&_h2]:font-bold [&_h3]:text-2xl [&_h3]:font-bold [&_h4]:text-2xl [&_h4]:font-bold">
                <RichTextLexical nodes={firstNode} />
              </div>
            )}
          </div>
          {rest && (
            <div class="[&_p]:text-muted-foreground">
              <RichTextLexical nodes={restNodes} />
            </div>
          )}
          <div class="mt-8 flex flex-col gap-2 sm:flex-row">
            {Array.isArray(links) && links.length > 0 ? (
              links.slice(0, 2).map(({ link }: any, i: number) => (
                <a
                  href={hrefFor(link)}
                  target={link?.newTab ? '_blank' : undefined}
                  rel={link?.newTab ? 'noopener noreferrer' : undefined}
                  class:list={[
                    buildButtonClasses(link?.appearance || (i === 0 ? 'default' : 'outline'), link?.size || 'default'),
                    'w-full sm:w-auto',
                  ]}
                >
                  {link?.label}
                </a>
              ))
            ) : (
              <a class={buildButtonClasses('default', 'default')} href="#">Get Started</a>
            )}
          </div>
        </div>
        {image?.url && (
          <img
            src={image.url}
            alt={image.alt || title || ''}
            class="aspect-video object-cover md:max-w-96"
            loading="lazy"
            decoding="async"
          />
        )}
      </div>
    </div>
  )
}
