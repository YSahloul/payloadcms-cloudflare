---
/**
 * Gallery Block — closer parity with enabled Payblocks Gallery variants.
 * Source of truth:
 *   - src/blocks/Gallery/gallery4.tsx
 *   - src/blocks/Gallery/gallery6.tsx
 *
 * Static Astro approximation of carousel variants using horizontal scroll.
 * Content only — wrapped by SectionShell.
 */
import RichTextLexical from '../richtext/RichTextLexical.astro'
import { resolveLinkUrl, resolveMediaUrl } from '../../../lib/styles'

const { richText, tagline, link, elements, designVersion } = Astro.props
const variant = designVersion || 'GALLERY4'
const items = Array.isArray(elements) ? elements : []
const nodes = richText?.root?.children || []

function imageUrl(item: any) {
  return item?.image && typeof item.image === 'object' ? resolveMediaUrl(item.image.url) : null
}
function imageAlt(item: any) {
  return item?.image && typeof item.image === 'object' ? item.image.alt || '' : ''
}
function itemNodes(item: any) {
  return item?.richText?.root?.children || []
}
---

{/* GALLERY4 — large overlay cards, horizontally scrollable */}
{
  variant === 'GALLERY4' && (
    <div>
      <div class="mb-8 flex items-end justify-between md:mb-14 lg:mb-16">
        {nodes.length > 0 && (
          <div class="max-w-3xl">
            <RichTextLexical
              nodes={nodes}
              overrideStyle={{
                h2: 'text-3xl font-medium md:text-4xl lg:text-5xl lg:mb-6 md:mb-4',
                h3: 'text-3xl font-medium md:text-4xl lg:text-5xl lg:mb-6 md:mb-4',
                p: 'text-muted-foreground',
              }}
            />
          </div>
        )}
        <div class="hidden shrink-0 gap-2 md:flex" aria-hidden="true">
          <span class="inline-flex size-10 items-center justify-center rounded-md hover:bg-accent">←</span>
          <span class="inline-flex size-10 items-center justify-center rounded-md hover:bg-accent">→</span>
        </div>
      </div>

      <div class="-mx-4 overflow-x-auto px-4 pb-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
        <div class="flex gap-5">
          {items.map((item: any) => (
            <a
              href={resolveLinkUrl(item.link)}
              class="group min-w-[320px] max-w-[360px] rounded-xl"
              target={item?.link?.newTab ? '_blank' : undefined}
              rel={item?.link?.newTab ? 'noopener noreferrer' : undefined}
            >
              <div class="group relative h-full min-h-[27rem] max-w-full overflow-hidden rounded-xl bg-red-200 md:aspect-[5/4] lg:aspect-video">
                {imageUrl(item) ? (
                  <img
                    src={imageUrl(item)}
                    alt={imageAlt(item)}
                    class="absolute size-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="absolute inset-0 bg-muted" />
                )}
                <div class="absolute inset-0 h-full bg-[linear-gradient(hsl(from_var(--primary)_h_s_l/0.2),hsl(from_var(--primary)_h_s_l/0.8)_100%)] mix-blend-multiply" />
                <div class="text-primary-foreground absolute inset-x-0 bottom-0 flex flex-col items-start p-6 md:p-8">
                  {itemNodes(item).length > 0 && (
                    <RichTextLexical
                      nodes={itemNodes(item)}
                      overrideStyle={{
                        h3: 'mb-2 pt-4 text-xl font-semibold md:mb-3 md:pt-4 lg:pt-4',
                        h4: 'mb-2 pt-4 text-xl font-semibold md:mb-3 md:pt-4 lg:pt-4',
                        p: 'mb-8 line-clamp-2 md:mb-12 lg:mb-9',
                      }}
                    />
                  )}
                  {item.link?.label && (
                    <span class="inline-flex items-center text-sm font-medium">
                      {item.link.label}<span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
                    </span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )
}

{/* GALLERY6 — card carousel layout, horizontally scrollable */}
{
  variant === 'GALLERY6' && (
    <div>
      <div class="mb-8 flex flex-col justify-between md:mb-14 md:flex-row md:items-end lg:mb-16">
        <div>
          {tagline && <p class="mb-6 text-xs font-medium tracking-wider uppercase">{tagline}</p>}
          {nodes.length > 0 && (
            <RichTextLexical
              nodes={nodes}
              overrideStyle={{
                h2: 'mb-3 text-xl font-semibold md:mb-4 md:text-4xl lg:mb-6',
                h3: 'mb-3 text-3xl font-semibold md:mb-4 md:text-4xl lg:mb-6',
              }}
            />
          )}
          {link?.label && (
            <a href={resolveLinkUrl(link)} class="group flex items-center text-xs font-medium md:text-base lg:text-lg">
              {link.label}<span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
            </a>
          )}
        </div>
        <div class="mt-8 flex shrink-0 items-center justify-center gap-2" aria-hidden="true">
          <span class="inline-flex size-10 items-center justify-center rounded-md border">←</span>
          <span class="inline-flex size-10 items-center justify-center rounded-md border">→</span>
        </div>
      </div>

      <div class="-mx-4 overflow-x-auto px-4 pb-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
        <div class="flex gap-5">
          {items.map((item: any) => (
            <a href={resolveLinkUrl(item.link)} class="group flex min-w-[320px] max-w-[452px] flex-col justify-between md:min-w-[452px]">
              <div>
                <div class="flex aspect-[3/2] rounded-xl text-clip overflow-hidden bg-muted">
                  <div class="flex-1">
                    {imageUrl(item) && (
                      <img
                        src={imageUrl(item)}
                        alt={imageAlt(item)}
                        class="size-full object-cover object-center transition duration-300 group-hover:scale-105"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                  </div>
                </div>
              </div>
              {itemNodes(item).length > 0 && (
                <RichTextLexical
                  nodes={itemNodes(item)}
                  overrideStyle={{
                    h2: 'mb-2 line-clamp-3 break-words pt-4 text-lg font-medium md:mb-3 md:pt-4 md:text-xl lg:pt-4 lg:text-2xl',
                    h3: 'mb-2 line-clamp-3 break-words pt-4 text-lg font-medium md:mb-3 md:pt-4 md:text-xl lg:pt-4 lg:text-2xl',
                    h4: 'mb-2 line-clamp-3 break-words pt-4 text-lg font-medium md:mb-3 md:pt-4 md:text-xl lg:pt-4 lg:text-2xl',
                    p: 'mb-8 line-clamp-2 text-sm text-muted-foreground md:mb-12 md:text-base lg:mb-9',
                  }}
                />
              )}
              <div class="flex items-center text-sm">Read more <span class="ml-2 transition-transform group-hover:translate-x-1">→</span></div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )
}

{/* Grid fallback for GALLERY5/GALLERY7/GALLERY25/GALLERY26 until individually ported. */}
{
  !['GALLERY4', 'GALLERY6'].includes(variant) && (
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
      {items.map((item: any) =>
        imageUrl(item) ? (
          <div class="aspect-square overflow-hidden rounded-lg">
            <img
              src={imageUrl(item)}
              alt={imageAlt(item)}
              class="size-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
        ) : null,
      )}
    </div>
  )
}
