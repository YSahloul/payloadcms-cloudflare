---
import RichTextLexical from '../richtext/RichTextLexical.astro'

const { heading, richText, authorName, authorRole, authorImage } = Astro.props
const hasRichText = richText?.root?.children?.length > 0
---

<div class="mx-auto max-w-3xl text-center">
  {heading && <h2 class="text-2xl md:text-3xl font-bold mb-6">{heading}</h2>}
  {hasRichText && (
    <div class="text-lg text-muted-foreground italic">
      <RichTextLexical nodes={richText.root.children} />
    </div>
  )}
  <div class="mt-6 flex items-center justify-center gap-3">
    {authorImage?.url && (
      <img src={authorImage.url} alt={authorName || ''} class="w-12 h-12 rounded-full object-cover" loading="lazy" />
    )}
    <div class="text-left">
      {authorName && <p class="font-medium">{authorName}</p>}
      {authorRole && <p class="text-sm text-muted-foreground">{authorRole}</p>}
    </div>
  </div>
</div>
