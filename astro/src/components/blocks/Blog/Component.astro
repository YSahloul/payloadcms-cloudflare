---
import RichTextLexical from '../richtext/RichTextLexical.astro'

const { heading, richText, posts } = Astro.props
const hasRichText = richText?.root?.children?.length > 0
---

<div>
  {heading && <h2 class="text-2xl md:text-3xl font-bold mb-4">{heading}</h2>}
  {hasRichText && <RichTextLexical nodes={richText.root.children} />}
  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {posts?.map((post: any) => (
      <article class="rounded-lg border bg-card p-4 hover:shadow-md transition-shadow">
        <a href={`/${post.slug}`} class="block">
          <h3 class="font-semibold hover:text-primary transition-colors">{post.title}</h3>
        </a>
      </article>
    ))}
  </div>
</div>
