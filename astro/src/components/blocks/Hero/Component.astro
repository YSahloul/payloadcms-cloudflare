---
/**
 * Hero Block — closer parity with original Payblocks hero variants.
 * Source of truth:
 *   - src/heros/PageHero/hero1.tsx
 *   - src/heros/PageHero/hero112.tsx
 *
 * Full-bleed, no SectionShell wrapper.
 */
import RichTextLexical from '../richtext/RichTextLexical.astro'
import { resolveLinkUrl, resolveMediaUrl, buildButtonClasses } from '../../../lib/styles'

const {
  backgroundColor,
  designVersion,
  badge,
  badgeIcon,
  tagline,
  richText,
  links,
  images,
  icons,
  statsItems,
  presentationVideo,
} = Astro.props

const variant = designVersion || '1'
const nodes = richText?.root?.children || []
const bg =
  backgroundColor && backgroundColor !== 'transparent' ? `bg-${backgroundColor}` : 'bg-base-100'
const text =
  !backgroundColor || backgroundColor === 'transparent' || backgroundColor === 'base-100'
    ? 'text-base-content'
    : backgroundColor === 'base-content'
      ? 'text-base-100'
      : `text-${backgroundColor}-content`
---

{/* HERO220 — closest existing Payblocks hero for RealTruck-style full-bleed video/media */}
{
  variant === '220' && (
    <section class="relative min-h-[82vh] overflow-hidden bg-black text-white">
      {presentationVideo?.videoUrl ? (
        <video
          class="absolute inset-0 size-full object-cover"
          src={presentationVideo.videoUrl}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        />
      ) : images?.[0]?.url ? (
        <img
          src={resolveMediaUrl(images[0].url)}
          alt={images[0].alt || ''}
          class="absolute inset-0 size-full object-cover"
          loading="eager"
          decoding="async"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-950 via-zinc-800 to-zinc-950" />
      )}
      <div class="absolute inset-0 bg-black/55" />
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 to-transparent" />

      <div class="relative z-10 mx-auto flex min-h-[82vh] max-w-7xl flex-col justify-end px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
        {tagline && <p class="mb-4 text-sm font-bold uppercase tracking-[0.24em] text-accent">{tagline}</p>}
        {nodes.length > 0 && (
          <div class="max-w-4xl">
            <RichTextLexical
              nodes={nodes}
              overrideStyle={{
                h1: 'max-w-4xl text-5xl font-black uppercase leading-[0.95] tracking-tight text-white md:text-7xl lg:text-8xl',
                p: 'mt-6 max-w-2xl text-lg font-medium text-white/85 md:text-xl',
              }}
            />
          </div>
        )}
        {Array.isArray(links) && links.length > 0 && (
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            {links.map(({ link }: any, i: number) => (
              <a
                href={resolveLinkUrl(link)}
                target={link?.newTab ? '_blank' : undefined}
                rel={link?.newTab ? 'noopener noreferrer' : undefined}
                class:list={[
                  i === 0
                    ? 'inline-flex h-12 items-center justify-center rounded-none bg-primary px-8 text-sm font-black uppercase tracking-wide text-white hover:bg-primary/90'
                    : 'inline-flex h-12 items-center justify-center rounded-none border-2 border-white bg-transparent px-8 text-sm font-black uppercase tracking-wide text-white hover:bg-white hover:text-black',
                  'w-full sm:w-auto',
                ]}
              >
                {link?.label}
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  )
}

{/* HERO112 — based on original Payblocks Hero112 */}
{
  variant === '112' && (
    <section class="bg-base-100 py-12 md:py-32">
      <div class="mx-auto max-w-[90rem] px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div class="flex flex-col gap-6 md:max-w-2xl">
            {nodes.length > 0 && (
              <div class="flex flex-col gap-6">
                <RichTextLexical
                  nodes={nodes}
                  overrideStyle={{
                    h1: 'text-4xl leading-tight font-medium lg:text-6xl',
                    p: 'text-lg text-base-content/60 lg:max-w-[80%]',
                  }}
                />
              </div>
            )}
            <div class="relative z-10 flex flex-wrap items-center gap-6">
              {Array.isArray(links) &&
                links.length > 0 &&
                links.map(({ link }: any, i: number) => (
                  <a
                    href={resolveLinkUrl(link)}
                    target={link?.newTab ? '_blank' : undefined}
                    rel={link?.newTab ? 'noopener noreferrer' : undefined}
                    class={buildButtonClasses(link?.appearance || 'default', link?.size || 'default')}
                  >
                    {link?.label}
                  </a>
                ))}

              {presentationVideo?.label && (
                <a
                  href={presentationVideo?.videoUrl || '#'}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center gap-2 hover:bg-transparent"
                >
                  <div class="flex h-10 w-10 rounded-full bg-primary transition-transform group-hover:scale-110 text-white text-sm font-bold">
                    <span class="m-auto">▶</span>
                  </div>
                  <div>{presentationVideo.label || 'Presentation Video'}</div>
                </a>
              )}
            </div>
          </div>
          <div>
            <div class="relative mx-auto mt-28 h-[21.25rem] w-[21.25rem] rounded-full bg-secondary md:mx-0 md:mt-0 lg:h-[25rem] lg:w-[25rem]">
              <div class="absolute bottom-0 left-1/2 w-[21.25rem] -translate-x-1/2 overflow-hidden rounded-b-full lg:w-[25rem]">
                {images && images.length > 0 && images[0]?.url && (
                  <img
                    src={images[0].url}
                    alt={images[0].alt || ''}
                    class="w-full translate-y-14 scale-90 object-cover object-center"
                    loading="eager"
                    decoding="async"
                  />
                )}
              </div>
              <div class="absolute -right-5 bottom-10 flex w-70 items-center justify-center gap-1 rounded-full bg-white px-4 py-3 shadow-md">
                <div class="flex -space-x-3.5">
                  {icons && icons.length > 0
                    ? icons.slice(0, 3).map((icon: any, i: number) => (
                        <div class="flex h-12 w-12 shrink-0 rounded-full border-4 border-white overflow-hidden bg-base-200 items-center justify-center">
                          {icon?.url ? (
                            <img src={icon.url} alt="" class="h-full w-full object-cover" loading="lazy" />
                          ) : (
                            <span class="text-xs font-semibold">{String.fromCharCode(65 + i)}</span>
                          )}
                        </div>
                      ))
                    : [0, 1, 2].map((_, i: number) => (
                        <div class="flex h-12 w-12 shrink-0 rounded-full border-4 border-white bg-base-200 items-center justify-center">
                          <span class="text-xs font-semibold">{String.fromCharCode(65 + i)}</span>
                        </div>
                      ))}
                </div>
                <div class="flex-1 text-sm text-base-content">
                  {tagline || '7000+ people already joined'}
                </div>
              </div>
              <div class="bg-primary absolute top-0 right-0 flex h-25 w-25 rotate-12 rounded-3xl border-8 border-white text-primary-content lg:h-[6.875rem] lg:w-[6.875rem]">
                <span class="m-auto text-3xl">📘</span>
              </div>
              <div class="bg-primary absolute top-1/3 -left-10 flex h-25 w-25 -rotate-12 rounded-3xl border-8 border-white text-primary-content lg:h-[6.875rem] lg:w-[6.875rem]">
                <span class="m-auto text-3xl">✏️</span>
              </div>
            </div>
          </div>
        </div>
        {Array.isArray(statsItems) && statsItems.length > 0 && (
          <div class="mt-20 rounded-3xl border p-6">
            <div class="flex w-full flex-col md:flex-row">
              {statsItems.map((item: any, index: number) => (
                <div
                  class:list={[
                    'flex flex-1 flex-col gap-3 p-6',
                    index < statsItems.length - 1 && 'border-b md:border-r md:border-b-0',
                  ]}
                >
                  <div class="text-primary text-2xl font-medium lg:text-4xl">{item.value}</div>
                  <div class="text-base-content/60 lg:text-lg">{item.title}</div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )
}

{/* HERO1 / default — based on original Payblocks Hero1 */}
{
  (variant === '1' || variant === 'none' || !['112', '220'].includes(variant)) && (
    <section class:list={['py-32', bg, text]}>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-8 lg:grid-cols-2">
          <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
            {badge && (
              <div class="inline-flex items-center rounded-full border px-3 py-1 text-sm">
                <span>{badge}</span>
                {badgeIcon && <span class="ml-2 text-xs">{badgeIcon}</span>}
              </div>
            )}
            {nodes.length > 0 && (
              <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
                <RichTextLexical
                  nodes={nodes}
                  overrideStyle={{
                    h1: 'my-6 text-pretty text-4xl font-bold lg:text-6xl',
                    p: 'mb-8 max-w-xl text-base-content/60 lg:text-xl',
                  }}
                />
              </div>
            )}
            {Array.isArray(links) && links.length > 0 && (
              <div class="flex w-full flex-col justify-center gap-2 sm:flex-row lg:justify-start">
                {links.map(({ link }: any, i: number) => (
                  <a
                    href={resolveLinkUrl(link)}
                    target={link?.newTab ? '_blank' : undefined}
                    rel={link?.newTab ? 'noopener noreferrer' : undefined}
                    class:list={[
                      buildButtonClasses(link?.appearance || 'default', link?.size || 'default'),
                      'w-full sm:w-auto',
                    ]}
                  >
                    {link?.label}
                  </a>
                ))}
              </div>
            )}
          </div>
          {images && images.length > 0 && images[0]?.url && (
            <img
              src={images[0].url}
              alt={images[0].alt || ''}
              class="max-h-96 w-full rounded-md object-cover"
              loading="eager"
              decoding="async"
            />
          )}
        </div>
      </div>
    </section>
  )
}
