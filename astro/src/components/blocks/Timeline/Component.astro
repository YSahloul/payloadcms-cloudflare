---
const { heading, events } = Astro.props
---

<div>
  {heading && <h2 class="text-2xl md:text-3xl font-bold mb-8">{heading}</h2>}
  <div class="relative mx-auto max-w-2xl border-l border-border pl-8">
    {events?.map((event: any) => (
      <div class="relative mb-8">
        <span class="absolute -left-[2.125rem] top-1.5 size-3 rounded-full bg-primary ring-4 ring-background" />
        <p class="text-sm text-muted-foreground">{event.date}</p>
        <h3 class="font-semibold mt-1">{event.title}</h3>
        <p class="text-muted-foreground mt-1">{event.description}</p>
      </div>
    ))}
  </div>
</div>
