---
import RichTextLexical from '../richtext/RichTextLexical.astro'

const { heading, casestudies } = Astro.props
---

<div>
  {heading && <h2 class="text-2xl md:text-3xl font-bold mb-8">{heading}</h2>}
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {casestudies?.map((item: any) => (
      <article class="rounded-lg border bg-card overflow-hidden hover:shadow-md transition-shadow">
        {item.image?.url && (
          <div class="aspect-video overflow-hidden">
            <img
              src={item.image.url}
              alt={item.image.alt || ''}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        )}
        <div class="p-4">
          <h3 class="font-semibold">{item.title}</h3>
          {item.richText?.root?.children?.length > 0 && (
            <div class="mt-2 text-sm text-muted-foreground">
              <RichTextLexical nodes={item.richText.root.children} />
            </div>
          )}
        </div>
      </article>
    ))}
  </div>
</div>
