---
const { heading, questions } = Astro.props
---

<div class="mx-auto max-w-2xl">
  {heading && <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">{heading}</h2>}
  <div class="divide-y divide-border">
    {questions?.map((q: any) => (
      <details class="py-4 group">
        <summary class="flex cursor-pointer items-center justify-between font-medium list-none text-left">
          <span>{q.question}</span>
          <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
        </summary>
        <div class="mt-2 text-muted-foreground text-left">{q.answer}</div>
      </details>
    ))}
  </div>
</div>
