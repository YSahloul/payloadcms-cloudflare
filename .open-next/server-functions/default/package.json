{
  "name": "payblocks",
  "version": "3.0.0",
  "description": "Payblocks CMS + Astro frontend on Cloudflare Workers",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./payload-types": "./src/payload-types.ts"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:astro": "cd astro && astro dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:astro": "cd astro && astro build",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "migrate": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate",
    "migrate:create": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate:create",
    "migrate:status": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate:status",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cms": "opennextjs-cloudflare build && wrangler deploy",
    "deploy:site": "cd astro && astro build && wrangler deploy",
    "deploy": "pnpm run deploy:cms && pnpm run deploy:site",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "tsc": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.80.0",
    "@payloadcms/db-d1-sqlite": "3.80.0",
    "@payloadcms/db-postgres": "3.80.0",
    "@payloadcms/email-resend": "3.80.0",
    "@payloadcms/live-preview-react": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/plugin-form-builder": "3.80.0",
    "@payloadcms/plugin-nested-docs": "3.80.0",
    "@payloadcms/plugin-redirects": "3.80.0",
    "@payloadcms/plugin-seo": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/storage-r2": "3.80.0",
    "@payloadcms/translations": "3.80.0",
    "@payloadcms/ui": "3.80.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@payloadcms/plugin-search": "3.80.0",
    "@payloadcms/storage-vercel-blob": "3.80.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^0.27.3",
    "bson": "^6.10.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-fade": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.0",
    "geist": "^1.7.0",
    "graphql": "^16.12.0",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "^0.483.0",
    "motion": "^12.34.0",
    "next": "15.4.11",
    "payload": "3.80.0",
    "payload-oauth2": "1.0.18",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.52.2",
    "react-icons": "^5.5.0",
    "react-phone-number-input": "^3.4.14",
    "react-responsive-masonry": "^2.7.1",
    "react-turnstile": "^1.1.5",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "tar-stream": "^3.1.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@next/bundle-analyzer": "15.4.11",
    "@next/eslint-plugin-next": "15.4.11",
    "@opennextjs/cloudflare": "^1.16.2",
    "@payloadcms/eslint-config": "^3.28.0",
    "@payloadcms/typescript-plugin": "3.80.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/escape-html": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "22.5.4",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@types/tar-stream": "^3.1.4",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.4.11",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.18",
    "typescript": "5.6.3",
    "wrangler": "~4.61.1"
  },
  "engines": {
    "node": "^18.20.2 || ^20.9.0 || ^22.0.0 || ^23.6.0 || ^24.6.0"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.13",
      "@types/react-dom": "19.2.3"
    }
  }
}
